# Copy to .env (git-ignored) and fill in your keys:
#   cp .env.example .env

# --- Groq ---------------------------------------------------------------
# Used by the Stop hook to summarize long notifications to a short
# English TLDR before sending to ntfy. Get a key at:
# https://console.groq.com/keys

GROQ_API_KEY=gsk_your_key_here

# Optional: override the summarization model (default: llama-3.3-70b-versatile)
# https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.1-8b-instant

# --- ElevenLabs ---------------------------------------------------------
# Used by the Stop hook to speak the repo name via ElevenLabs TTS
# (cached per phrase under ~/.claude/cache/tts; falls back to macOS
# `say` when unset). Get a key at:
# https://elevenlabs.io/app/settings/api-keys

ELEVENLABS_API_KEY=sk_your_key_here

# Optional: override the voice (default: JBFqnCBsd6RMkjVDRZzb "George")
# https://elevenlabs.io/app/voice-library
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Optional: override the TTS model (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL=eleven_flash_v2_5
