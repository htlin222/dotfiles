# Copy to .env (git-ignored) and fill in your key:
#   cp .env.example .env
#
# Used by the Stop hook to summarize long notifications to ≤50-char
# zh-TW via Groq before sending to ntfy. Get a key at:
# https://console.groq.com/keys

GROQ_API_KEY=gsk_your_key_here

# Optional: override the summarization model (default: llama-3.3-70b-versatile)
# https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.1-8b-instant
