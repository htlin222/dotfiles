# cf-gate credentials — copy to .env (chmod 600). NEVER commit .env.
#
# Mint the token once at https://dash.cloudflare.com/profile/api-tokens
# with these permissions (the only GUI step you ever need):
#   Account → Access: Apps and Policies → Edit
#   Account → Access: Organizations, Identity Providers, and Groups → Read
#   Account → Cloudflare Pages → Edit        (only for `pages-domain`)
#   Zone    → DNS → Edit  (zone: hsiehting.com; only for `pages-domain` auto-DNS)

CF_API_TOKEN=
CF_ACCOUNT_ID=

# Default allow-list for `cf-gate gate <host>` when no emails are passed.
# Space/comma separated. Use @domain.com to allow any address on that domain.
CF_GATE_EMAILS="mail@hsiehting.com ppoiu87@gmail.com"

# Fallback only (discouraged — full-access): global API key + account email.
# CF_API_KEY=
# CF_API_EMAIL=
