#!/usr/bin/env bash
#
# bootstrap — full machine setup: Homebrew, oh-my-zsh, symlinks, deps.

set -e

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

source "$DOTFILES_ROOT/start/lib/ui.sh"
source "$DOTFILES_ROOT/start/lib/links.sh"

install_homebrew() {
  ui_step "Homebrew"
  if command -v brew >/dev/null 2>&1; then
    ui_ok "already installed ${C_DIM}($(command -v brew))${C_RESET}"
  else
    ui_info "installing Homebrew (this may prompt for your password)…"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    ui_ok "Homebrew installed"
  fi
}

install_ohmyzsh() {
  ui_step "oh-my-zsh"
  if [ -d "$HOME/.oh-my-zsh" ]; then
    ui_ok "already installed"
  else
    ui_info "installing oh-my-zsh…"
    # --unattended: don't chsh or exec zsh mid-bootstrap
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    ui_ok "oh-my-zsh installed"
  fi
}

main() {
  ui_banner "dotfiles bootstrap" "$DOTFILES_ROOT"

  if [ "$(uname -s)" = "Darwin" ]; then
    ui_steps_total 4
  else
    ui_steps_total 3
  fi

  install_homebrew
  install_ohmyzsh

  ui_step "Symlinks"
  install_dotfiles
  links_summary

  if [ "$(uname -s)" = "Darwin" ]; then
    ui_step "macOS dependencies"
    if source "$DOTFILES_ROOT/bin/dot"; then
      ui_ok "dependencies installed"
    else
      ui_fail "error installing dependencies"
    fi
  fi

  ui_done "All installed!"
}

main "$@"
