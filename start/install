#!/usr/bin/env bash
#
# install — run brew bundle, then every topic install.sh installer.

set -e

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

source "$DOTFILES_ROOT/start/lib/ui.sh"

usage() {
  cat <<'EOF'
Usage: start/install [options]

Run `brew bundle`, then every topic install.sh installer.

Options:
  -y, --non-interactive   Unattended (sets NONINTERACTIVE=1 for installers;
                          auto-enabled when there's no TTY)
  -h, --help              Show this help
EOF
}

# Non-interactive when asked, or when there's no TTY (CI / agent runs).
[ "${UI_TTY:-true}" = false ] && export NONINTERACTIVE=1
while [ $# -gt 0 ]; do
  case "$1" in
    -y | --yes | --non-interactive | --noninteractive) export NONINTERACTIVE=1 ;;
    -h | --help) usage; exit 0 ;;
    *) ui_warn "ignoring unknown option: ${C_BOLD}$1${C_RESET}" ;;
  esac
  shift
done

ui_banner "dotfiles install" "brew bundle + topic installers"
ui_steps_total 2

ui_step "Homebrew bundle"
if command -v brew >/dev/null 2>&1; then
  # Streamed (not spinnered): brew bundle output is long and useful.
  brew bundle
  ui_ok "brew bundle complete"
else
  ui_warn "brew not found — skipping bundle"
fi

ui_step "Topic installers"
found=0
failed=0
while IFS= read -r installer; do
  found=$((found + 1))
  ui_run "${installer#./}" sh "$installer" || failed=$((failed + 1))
done < <(find . -name install.sh -not -path './.git/*' | sort)

if [ "$found" -eq 0 ]; then
  ui_info "no install.sh scripts found"
elif [ "$failed" -gt 0 ]; then
  ui_warn "$failed of $found installers failed"
fi

ui_done "Install complete!"
