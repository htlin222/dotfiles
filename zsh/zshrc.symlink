function icdn() {
    GREEN="\033[32m"
    RESET="\033[0m"
    echo "The following files are in the cloud nine:"
    find . -name '.*icloud'
    find . -name '.*icloud' | perl -pe 's|(.*)/.(.*).icloud|$1/$2|s' | while read file; do brctl download "$file"; done
    echo "\n${GREEN}Start to download all the files, be patient! ⏱️ ${RESET}"
}
