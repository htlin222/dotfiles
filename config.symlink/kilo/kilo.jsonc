{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": {
    "bash": {
      "curl *": "allow",
      "echo *": "allow",
      "ls *": "allow",
      "npm run relay *": "allow",
      "sleep *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "python3 *": "allow"
    },
    "external_directory": {
      "/tmp/*": "allow"
    }
  }
}